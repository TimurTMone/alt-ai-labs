# ── Supabase ─────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe (optional — not wired yet) ───────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_ID=price_xxx

# ── Vercel KV (for waitlist — auto-set on Vercel) ───────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Build Mode ──────────────────────────────────────────────────
# Set to "static" for Capacitor mobile builds (generates /out)
# Leave unset for normal Vercel deployment (SSR)
# BUILD_MODE=static
