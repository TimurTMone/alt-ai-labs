# ── Supabase ─────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ELITE_PRICE_ID=price_xxx

# ── Resend (email) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Alt AI Labs <noreply@altailabs.com>

# ── Vercel KV (for waitlist + rate limiting — auto-set on Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Build Mode ──────────────────────────────────────────────────
# Set to "static" for Capacitor mobile builds (generates /out)
# Leave unset for normal Vercel deployment (SSR)
# BUILD_MODE=static
