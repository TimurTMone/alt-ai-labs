# ============================================================
# FRONTEND (Next.js) — read at build + runtime
# ============================================================

# Public URLs
NEXT_PUBLIC_APP_URL=https://altailabs.club
NEXT_PUBLIC_API_URL=https://api.altailabs.club

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ELITE_PRICE_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Altai Labs Club <noreply@altailabs.club>

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_META_PIXEL_ID=

# ============================================================
# BACKEND (Express at /server) — read by server/index.js
# ============================================================

# Postgres — local on Hetzner
DATABASE_URL=postgresql://altailabs_club_user:PASSWORD@127.0.0.1:5432/altailabs_club

# Auth
JWT_SECRET=

# URLs (for CORS + OAuth redirects)
FRONTEND_URL=https://altailabs.club
API_URL=https://api.altailabs.club

# Google OAuth (optional — Sign in with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# AI (Claude) — same key as altailabs.ai can be used
ANTHROPIC_API_KEY=
