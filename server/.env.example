# Render PostgreSQL connection
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (generate a random 64-char string)
JWT_SECRET=your-secret-here

# Frontend URL (for CORS + OAuth redirects)
FRONTEND_URL=https://alt-ai-labs.vercel.app

# This server's public URL (for OAuth callback URLs)
API_URL=https://alt-ai-labs-api.onrender.com

# Apple Sign In (developer.apple.com → Certificates → Keys → Sign in with Apple)
APPLE_SERVICE_ID=com.altailabs.app.signin
# APPLE_TEAM_ID=PJPHU42VG4
# APPLE_KEY_ID=your-key-id
# APPLE_PRIVATE_KEY=your-private-key

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0 Client)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Port (Render sets this automatically)
PORT=3001
